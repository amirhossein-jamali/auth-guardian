# Docker PostgreSQL Environment Variables
POSTGRES_USER=auth_guardian_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=auth_guardian_db

# Application Database Connection Parameters
DB_HOST=postgres
DB_PORT=5432
DB_USER=auth_guardian_user
DB_PASSWORD=your_secure_password
DB_NAME=auth_guardian_db
DB_SSL_MODE=disable
DB_MAX_CONNECTIONS=20
DB_MAX_IDLE_CONNECTIONS=5
DB_CONNECTION_MAX_LIFETIME=1h

# Environment variables for the application (with AUTH_GUARDIAN prefix)
AUTH_GUARDIAN_DB_HOST=postgres
AUTH_GUARDIAN_DB_PORT=5432
AUTH_GUARDIAN_DB_USER=auth_guardian_user
AUTH_GUARDIAN_DB_PASSWORD=your_secure_password
AUTH_GUARDIAN_DB_NAME=auth_guardian_db
AUTH_GUARDIAN_DB_SSL_MODE=disable 